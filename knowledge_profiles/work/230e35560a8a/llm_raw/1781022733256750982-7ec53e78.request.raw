{"model": "doubao-seed-2-0-pro-260215", "input": [{"type": "message", "role": "user", "content": [{"type": "input_text", "text": "{\"samples\": [{\"id\": \"sample\", \"kind\": \"video\", \"name\": \"knowledge_fp30.mp4\", \"video_meta\": {\"path\": \"/home/bridge/coding/sakugacut/exp65v3/knowledge_profiles/work/230e35560a8a/uploads/knowledge_fp30.mp4\", \"name\": \"knowledge_fp30.mp4\", \"kind\": \"video\", \"mime\": \"video/mp4\", \"size\": 18443588, \"duration\": 102.334, \"width\": 720, \"height\": 1280, \"fps\": 30.0, \"has_audio\": true, \"has_video\": true, \"probe\": {\"streams\": [{\"index\": 0, \"codec_name\": \"aac\", \"codec_long_name\": \"AAC (Advanced Audio Coding)\", \"profile\": \"LC\", \"codec_type\": \"audio\", \"codec_tag_string\": \"mp4a\", \"codec_tag\": \"0x6134706d\", \"sample_fmt\": \"fltp\", \"sample_rate\": \"44100\", \"channels\": 2, \"channel_layout\": \"stereo\", \"bits_per_sample\": 0, \"r_frame_rate\": \"0/0\", \"avg_frame_rate\": \"0/0\", \"time_base\": \"1/44100\", \"start_pts\": 0, \"start_time\": \"0.000000\", \"duration_ts\": 4511680, \"duration\": \"102.305669\", \"bit_rate\": \"128073\", \"nb_frames\": \"4408\", \"disposition\": {\"default\": 1, \"dub\": 0, \"original\": 0, \"comment\": 0, \"lyrics\": 0, \"karaoke\": 0, \"forced\": 0, \"hearing_impaired\": 0, \"visual_impaired\": 0, \"clean_effects\": 0, \"attached_pic\": 0, \"timed_thumbnails\": 0}, \"tags\": {\"language\": \"und\", \"handler_name\": \"SoundHandler\", \"vendor_id\": \"[0][0][0][0]\"}}, {\"index\": 1, \"codec_name\": \"h264\", \"codec_long_name\": \"H.264 / AVC / MPEG-4 AVC / MPEG-4 part 10\", \"profile\": \"High\", \"codec_type\": \"video\", \"codec_tag_string\": \"avc1\", \"codec_tag\": \"0x31637661\", \"width\": 720, \"height\": 1280, \"coded_width\": 720, \"coded_height\": 1280, \"closed_captions\": 0, \"has_b_frames\": 2, \"sample_aspect_ratio\": \"1:1\", \"display_aspect_ratio\": \"9:16\", \"pix_fmt\": \"yuv420p\", \"level\": 31, \"color_range\": \"tv\", \"color_space\": \"bt709\", \"color_transfer\": \"bt709\", \"color_primaries\": \"bt709\", \"chroma_location\": \"left\", \"refs\": 1, \"is_avc\": \"true\", \"nal_length_size\": \"4\", \"r_frame_rate\": \"30/1\", \"avg_frame_rate\": \"30/1\", \"time_base\": \"1/15360\", \"start_pts\": 0, \"start_time\": \"0.000000\", \"duration_ts\": 1571840, \"duration\": \"102.333333\", \"bit_rate\": \"1305094\", \"bits_per_raw_sample\": \"8\", \"nb_frames\": \"3070\", \"disposition\": {\"default\": 1, \"dub\": 0, \"original\": 0, \"comment\": 0, \"lyrics\": 0, \"karaoke\": 0, \"forced\": 0, \"hearing_impaired\": 0, \"visual_impaired\": 0, \"clean_effects\": 0, \"attached_pic\": 0, \"timed_thumbnails\": 0}, \"tags\": {\"language\": \"und\", \"handler_name\": \"VideoHandler\", \"vendor_id\": \"[0][0][0][0]\"}}], \"format\": {\"filename\": \"/home/bridge/coding/sakugacut/exp65v3/knowledge_profiles/work/230e35560a8a/uploads/knowledge_fp30.mp4\", \"nb_streams\": 2, \"nb_programs\": 0, \"format_name\": \"mov,mp4,m4a,3gp,3g2,mj2\", \"format_long_name\": \"QuickTime / MOV\", \"start_time\": \"0.000000\", \"duration\": \"102.334000\", \"size\": \"18443588\", \"bit_rate\": \"1441834\", \"probe_score\": 100, \"tags\": {\"major_brand\": \"isom\", \"minor_version\": \"512\", \"compatible_brands\": \"isomiso2avc1mp41\", \"comment\": \"vid:v0d00fg10000d2slvknog65ttjs9qhfg\", \"encoder\": \"Lavf58.76.100\"}}}, \"errors\": []}, \"video_parts\": [{\"start_time\": 0.0, \"end_time\": 2.8, \"description\": \"画面为电钢琴按键区域特写，底部出现白色字幕“来听一下它的外放声音”，随后手部入镜按下电钢琴功能按键，节奏明快直接点明视频核心展示点，可迁移到数码产品类视频开头，快速点明测试/展示主题，抓住观众注意力。\"}, {\"start_time\": 2.9, \"end_time\": 48.0, \"description\": \"镜头环绕拉远移动拍摄，依次展示电钢琴整体琴身、原装木质支架、底部三踏板、配套琴凳，节奏舒缓，完整呈现产品整体形态与配套部件，可迁移到大件数码、家具类产品的全景外观展示，让观众快速建立对产品的整体认知。\"}, {\"start_time\": 48.1, \"end_time\": 57.8, \"description\": \"画面为电钢琴中景，底部依次出现白色字幕“罗兰的FP30到货了”“原装的木架三踏板的”“一台FP30，88键重锤的”，镜头同时扫过琴身侧面的“FP30”型号标识，传递产品核心型号与基础配置信息，可迁移到新品/二手到货类视频的基础参数介绍，快速给观众传递核心产品信息。\"}, {\"start_time\": 57.9, \"end_time\": 68.4, \"description\": \"镜头扫过琴身Roland品牌标识、侧面型号标识，底部依次出现白色字幕“FP30和FP30X两个外观功能”“基本是一样的”，做同系列产品的差异说明，打消用户对型号区别的疑问，可迁移到同系列不同款产品的科普环节，减少用户决策疑问。\"}, {\"start_time\": 68.5, \"end_time\": 78.4, \"description\": \"镜头特写琴身无磕碰的外壳部位、配套琴凳，底部依次出现白色字幕“状态非常的好”“没有明显的磕碰刮痕”“整体有九成新 有琴凳”“有多种功能可以选择”，展示产品成色与附加配件，突出产品品相优势，可迁移到二手产品类视频的成色展示环节，增强用户信任感。\"}, {\"start_time\": 78.5, \"end_time\": 88.7, \"description\": \"镜头依次特写电钢琴功能按键区、琴键细节，底部依次出现白色字幕“这款采用的琴键”“和FP 30X也是同款的”“来听一下这台琴的音色”，先介绍核心部件的卖点，再引出后续的音色实测，过渡自然，可迁移到产品核心卖点介绍到实测环节的过渡片段，引导观众继续观看实测内容。\"}, {\"start_time\": 88.8, \"end_time\": 102.3, \"description\": \"手部入镜弹奏电钢琴的不同区域按键，展示按键按下的反馈同时输出电钢琴外放音色，最后手部离开镜头，为核心功能实测环节，直观展示产品使用体验与核心性能，可迁移到乐器、音频类产品的真实使用场景测试，用实际体验证明产品品质。\"}], \"music_parts\": [{\"start_time\": 0.0, \"end_time\": 2.8, \"description\": \"极低环境噪音下的男声引导语片段，用于快速收拢观众注意力，可适配各类测评内容的开场引入场景\"}, {\"start_time\": 3.2, \"end_time\": 47.7, \"description\": \"慢节奏抒情钢琴独奏，后续自然过渡到搭配轻快爵士伴奏的流行钢琴段落，音色温润柔和低干扰，可作为产品展示环节的治愈系背景BGM基底\"}, {\"start_time\": 48.1, \"end_time\": 89.7, \"description\": \"低音量垫乐搭配男声平缓讲解电钢琴配置成色的段落，信息传递清晰节奏松弛，可作为数码乐器测评的参数解说配套音段\"}, {\"start_time\": 90.2, \"end_time\": 101.9, \"description\": \"极速炫技的高难度钢琴琶音表演片段，技巧表现力强听觉冲击力足，可作为乐器性能展示的高光收尾特效音段\"}], \"asr_parts\": [{\"start_time\": 0.1, \"end_time\": 2.1, \"text\": \"来听一下它的外放声音\"}, {\"start_time\": 48.3, \"end_time\": 61.7, \"text\": \"罗兰的FP三零到货了啊原装的木架三踏板的一台FP三零八十八键重锤的FP三零和FP三零\"}, {\"start_time\": 62.0, \"end_time\": 90.3, \"text\": \"X两个外观功能啊基本是一样的状态非常的好没有明显的磕碰划痕整体有九成新啊有琴凳有多种功能可以选择这款采用的琴键和FP三零X也是同款的啊来听一下这台琴的音色\"}], \"notes\": [\"extracted_audio_path=/home/bridge/coding/sakugacut/exp65v3/knowledge_profiles/work/230e35560a8a/audio/knowledge_fp30_audio.wav\", \"audio_profile=speech_present\"]}], \"task\": \"请基于这些样例视频分析结果生成 struct_info 字符串。\"}"}]}], "instructions": "你是短视频样例结构复盘专家。\n你总结视频，后生成一个struct_info。\nstruct_info 必须是一个可直接交给剪辑 agent 参考的中文字符串，按以下三个小节组织：\n- **脚本/段落结构**：如开头 hook、中段展开、结尾 CTA\n- **包装结构**：如字幕密度、标题条、贴纸、转场、封面风格\n- **背景音乐结构/描述**：如果有音乐，说说视频中音乐的结构/描述\n如果某项无法从输入判断，明确写“未从样例中识别到”，不要编造。", "text": {"format": {"type": "json_schema", "name": "sample_struct_info", "strict": true, "schema": {"type": "object", "properties": {"struct_info": {"type": "string", "description": "对样例视频脚本、包装、背景音乐结构的中文总结，保留 markdown 小节标题。"}}, "required": ["struct_info"], "additionalProperties": false}}}}