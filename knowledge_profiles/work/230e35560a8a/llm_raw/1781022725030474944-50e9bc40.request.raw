{"model": "ep-20260508213828-7ntjl", "input": [{"type": "message", "role": "user", "content": [{"type": "input_audio", "file_id": "file-20260610003201-7f42x"}, {"type": "input_text", "text": "请语音转写这段音频，并尽量给出句级时间戳。start_time 和 end_time 使用秒，统一保留小数点后一位。"}]}], "instructions": "你是 ASR 专家。识别音频中的语音；若没有可识别人声，返回空 parts。", "text": {"format": {"type": "json_schema", "name": "asr_ir", "strict": true, "schema": {"type": "object", "properties": {"parts": {"type": "array", "items": {"type": "object", "properties": {"start_time": {"type": "number", "description": "语音开始时间，单位秒，保留小数点后一位。"}, "end_time": {"type": "number", "description": "语音结束时间，单位秒，保留小数点后一位。"}, "text": {"type": "string", "description": "转写文本。"}}, "required": ["start_time", "end_time", "text"], "additionalProperties": false}, "description": "句级语音片段。无可识别人声时为空数组。"}}, "required": ["parts"], "additionalProperties": false}}}}